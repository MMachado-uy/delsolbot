{
  "name": "delsolbot",
  "version": "3.0.1",
  "description": "Integration between radio station RSS feeds and Telegram bot to publish in the corresponding Telegram channels",
  "main": "app.js",
  "keywords": [
    "nodejs",
    "mysql",
    "rss",
    "telegram-bot-api",
    "telegram"
  ],
  "author": "Mauricio Machado",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MMachado-uy/delsolbot.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node app.js",
    "startdb": "./database/dbset.sh",
    "updatedb": "./database/dbset.sh --no-seed",
    "dev": "nodemon app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint ."
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cron": "^3.5.0",
    "dotenv": "^16.4.7",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.1",
    "luxon": "^3.5.0",
    "mysql2": "^3.12.0",
    "node-id3": "^0.2.6",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.19.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14"
  }
}
