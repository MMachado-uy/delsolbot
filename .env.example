DB = replaceme
DB_USER = replaceme
DB_PASS = replaceme
DB_PORT = replaceme
DB_HOST = replaceme

BOT_TOKEN = replaceme
TEST_CHANNEL = replaceme

NODE_ENV = replaceme
DEBUG = replaceme
CRON = replaceme
CRON_CLEANUP = replaceme

# Operator alerts (optional). ADMIN_CHAT_ID = your personal chat id with the bot;
# you must message the bot once (/start) first — bots can't initiate a chat.
# Leave ADMIN_CHAT_ID unset to disable the daily summary + crash alerts entirely.
ADMIN_CHAT_ID = replaceme
CRON_SUMMARY = 0 0 * * *

# Optional Telegram upload tuning (defaults shown; safe to omit)
TELEGRAM_TIMEOUT_MS = 120000
TELEGRAM_SEND_RETRIES = 3
TELEGRAM_RETRY_DELAY_MS = 2000
